# ========================================
# Backend — Node.js / Express / Prisma / MySQL
# ========================================

# Dependencies
node_modules/

# Environment — NEVER commit real credentials
.env
.env.*
!.env.example

# Prisma
# schema.prisma and migrations/ ARE committed (DB source of truth).
# Ignore local SQLite fallbacks and query engine binaries if any.
prisma/*.db
prisma/*.db-journal
prisma/dev.db*

# MySQL local dumps
*.sql.gz
*.sql.bak
dump.sql
dump-*.sql

# Logs
*.log
npm-debug.log*
logs/

# Build / runtime
dist/
build/
coverage/
.nyc_output/

# OS / IDE
.DS_Store
Thumbs.db
.idea/
.vscode/

# Placeholder file (no longer needed now that real files exist)
.gitkeep
